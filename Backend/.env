DB_NAME=FakeRestaurantDemo

# ======================================================
# CONFIGURAZIONE SMTP (Invio Email)
# ======================================================
# Host del server SMTP (es. smtp.gmail.com per Gmail)
SMTP_HOST=smtp.gmail.com
# Porta del server SMTP (587 per TLS, 465 per SSL)
SMTP_PORT=587
# Indica se usare una connessione sicura (true per 465, false per 587)
SMTP_SECURE=false
# Indirizzo email utilizzato per l'autenticazione SMTP
SMTP_USER=fakerestauranttest@gmail.com
# Password o App Password per l'autenticazione SMTP
SMTP_PASS=zrsu dity jdpp kbfn
# Mittente che apparirà nelle email inviate
SMTP_FROM="FakeRestaurant <fakerestauranttest@gmail.com>"

# ======================================================
# CONFIGURAZIONE APPLICAZIONE
# ======================================================
# URL del frontend per la configurazione CORS (chi può chiamare le API)
FRONTEND_URL=http://localhost:4200
# Chiave segreta per firmare e verificare i token JWT (minimo 32 caratteri)
JWT_SECRET=b2d9f1f8a72c4d58e3c9a1b7d4f6e2c1b9f6d4c2a1e5f7b8c3d2a9f1e3c5b7
